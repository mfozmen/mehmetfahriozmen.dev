{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "push": true,
    "requireCleanWorkingDir": true,
    "requireBranch": "dev"
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:release": "git push origin HEAD:main"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md",
      "context": {
        "host": "https://github.com",
        "owner": "mfozmen",
        "repository": "mehmetfahriozmen.dev"
      }
    }
  }
}
